# Prisma — string de conexão com o banco de dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Google Gemini — chave de API para guia local e chat assistente
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."

# Modelo Gemini (opcional — padrão: gemini-2.0-flash)
GEMINI_MODEL="gemini-2.0-flash"