# URL pública do site (usada em Open Graph e links absolutos)
NEXT_PUBLIC_SITE_URL="https://guia.seazone.com.br"

# Prisma — string de conexão com o banco de dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Google Gemini — chave de API para guia local e chat assistente (obrigatório em produção)
# Obtenha em https://aistudio.google.com/apikey — use chave do AI Studio (prefixo AIza)
GEMINI_API_KEY="AIza..."

# Modelo Gemini (opcional — padrão: gemini-2.0-flash)
# Free tier: se gemini-2.5-flash esgotar cota, use gemini-2.5-flash-lite
GEMINI_MODEL="gemini-2.5-flash-lite"